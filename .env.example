# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:password@postgres:5432/aiagent

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
APP_NAME=AI Agent Platform

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Agent Workspace ───────────────────────────────────────────────────────────
AGENT_WORK_DIR=/tmp/agent_workspace
