# --- System / OS ---
.DS_Store
Thumbs.db
*.log
*.tmp

# --- Environments & Secrets (CRITICAL) ---
# Prevents leaking Supabase keys or service account tokens
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.[development|production]
.env.sample

# --- Node.js & Next.js (apps/landing) ---
node_modules/
.next/
out/
build/
dist/
.vercel/
.turbo/
npm-debug.log*

# --- Python & FastAPI (services/core & scripts) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.pytest_cache/
.mypy_cache/
.pyright_cache/
# Playwright browser binaries used in your scrapers
pw-browsers/

# --- Mobile (apps/mobile) ---
.expo/
*.jks
*.p12
*.key
*.mobileprovision

# --- Data & Security ---
# Protects the 50,000+ mock records and security audit logs
data/*.csv
data/*.json
!data/.gitkeep
local_security_audit_report.json

# --- Infrastructure ---
# Prevents committing local database volumes
.db_data/
postgres_data/
